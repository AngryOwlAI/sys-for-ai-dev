{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/sys-for-ai/schemas/contracts/validation_contract_registry_row.schema.json",
  "title": "Validation contract registry row",
  "type": "object",
  "required": [
    "contract_id",
    "path",
    "dialect",
    "target_format",
    "target_artifact_type",
    "target_glob",
    "authority_status",
    "owner",
    "validator_command",
    "supersedes",
    "source_hash",
    "last_validated_at",
    "notes"
  ],
  "properties": {
    "contract_id": { "type": "string", "pattern": "^contract_[a-z0-9_]+$" },
    "path": { "type": "string", "minLength": 1 },
    "dialect": { "enum": ["2020-12"] },
    "target_format": { "enum": ["yaml", "toml", "csv", "json"] },
    "authority_status": { "enum": ["controlled", "canonical", "canonical_draft", "draft"] }
  },
  "additionalProperties": { "type": "string" }
}
