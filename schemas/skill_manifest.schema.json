{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/sys-for-ai/schemas/skill_manifest.schema.json",
  "title": "Skill Manifest",
  "description": "Schema for a system-agnostic skill manifest used by the sys-for-ai skill operating layer.",
  "type": "object",
  "required": [
    "skill_id",
    "version",
    "status",
    "canonical_path",
    "summary",
    "scope",
    "domain_emphasis",
    "required_role_posture",
    "activation",
    "inputs",
    "outputs",
    "dependencies",
    "authority",
    "validation",
    "handoff"
  ],
  "properties": {
    "skill_id": {
      "$ref": "#/$defs/skillId"
    },
    "version": {
      "$ref": "#/$defs/semver"
    },
    "status": {
      "type": "string",
      "enum": [
        "candidate",
        "draft",
        "template",
        "active",
        "deprecated",
        "shim"
      ]
    },
    "canonical_path": {
      "$ref": "#/$defs/relativePath"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "object",
      "required": [
        "system_agnostic",
        "target_system_types"
      ],
      "properties": {
        "system_agnostic": {
          "type": "boolean"
        },
        "target_system_types": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "intentional_specialization": {
          "type": "string"
        },
        "exemptions": {
          "$ref": "#/$defs/stringArray"
        }
      },
      "additionalProperties": true
    },
    "domain_emphasis": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "required_role_posture": {
      "type": "array",
      "description": "Must include system_analyst, system_engineer, and software_engineer unless an explicit exemption is recorded.",
      "items": {
        "$ref": "#/$defs/roleId"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "optional_role_posture": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/roleId"
      },
      "uniqueItems": true
    },
    "activation": {
      "type": "object",
      "required": [
        "triggers"
      ],
      "properties": {
        "triggers": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "when_not_to_use": {
          "$ref": "#/$defs/stringArray"
        },
        "preconditions": {
          "$ref": "#/$defs/stringArray"
        }
      },
      "additionalProperties": true
    },
    "inputs": {
      "$ref": "#/$defs/inputOutputContract"
    },
    "outputs": {
      "$ref": "#/$defs/outputContract"
    },
    "dependencies": {
      "type": "object",
      "required": [
        "required_skills",
        "optional_skills",
        "python"
      ],
      "properties": {
        "required_skills": {
          "$ref": "#/$defs/skillIdArray"
        },
        "optional_skills": {
          "$ref": "#/$defs/skillIdArray"
        },
        "validation_skills": {
          "$ref": "#/$defs/skillIdArray"
        },
        "domain_required_skills": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/skillIdArray"
          }
        },
        "python": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "type": "object",
              "properties": {
                "requirements_file": {
                  "$ref": "#/$defs/relativePath"
                },
                "standard_library_only": {
                  "type": "boolean"
                },
                "notes": {
                  "type": "string"
                }
              },
              "additionalProperties": true
            }
          ]
        },
        "external_tools": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "$ref": "#/$defs/externalTool"
              }
            ]
          }
        }
      },
      "additionalProperties": true
    },
    "authority": {
      "type": "object",
      "required": [
        "may_read",
        "may_write",
        "may_not"
      ],
      "properties": {
        "may_read": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "may_write": {
          "$ref": "#/$defs/stringArray"
        },
        "may_not": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "canonical_sources": {
          "$ref": "#/$defs/stringArray"
        },
        "generated_derivatives": {
          "$ref": "#/$defs/stringArray"
        },
        "human_gates": {
          "$ref": "#/$defs/stringArray"
        }
      },
      "additionalProperties": true
    },
    "validation": {
      "type": "object",
      "required": [
        "commands",
        "validator_classes"
      ],
      "properties": {
        "commands": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "$ref": "#/$defs/validationCommand"
              }
            ]
          }
        },
        "validator_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/validatorClass"
          },
          "uniqueItems": true
        },
        "contextual_validation_rationale": {
          "type": "string"
        },
        "evidence_required": {
          "$ref": "#/$defs/stringArray"
        }
      },
      "additionalProperties": true
    },
    "handoff": {
      "type": "object",
      "required": [
        "requires_completion_receipt",
        "evidence"
      ],
      "properties": {
        "requires_completion_receipt": {
          "type": "boolean"
        },
        "evidence": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "next_role": {
          "type": "string"
        },
        "open_issue_policy": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "failure_modes": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "object",
            "required": [
              "mode",
              "recovery"
            ],
            "properties": {
              "mode": {
                "type": "string",
                "minLength": 1
              },
              "recovery": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": true
          }
        ]
      }
    },
    "compatibility_shims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "purpose"
        ],
        "properties": {
          "path": {
            "$ref": "#/$defs/relativePath"
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "last_synchronized": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "allOf": [
    {
      "if": {
        "not": {
          "properties": {
            "scope": {
              "required": [
                "exemptions"
              ],
              "properties": {
                "exemptions": {
                  "contains": {
                    "const": "required_role_posture"
                  }
                }
              }
            }
          },
          "required": [
            "scope"
          ]
        }
      },
      "then": {
        "properties": {
          "required_role_posture": {
            "allOf": [
              {
                "contains": {
                  "const": "system_analyst"
                }
              },
              {
                "contains": {
                  "const": "system_engineer"
                }
              },
              {
                "contains": {
                  "const": "software_engineer"
                }
              }
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "validation": {
            "properties": {
              "commands": {
                "maxItems": 0
              }
            },
            "required": [
              "commands"
            ]
          }
        },
        "required": [
          "validation"
        ]
      },
      "then": {
        "properties": {
          "validation": {
            "required": [
              "contextual_validation_rationale"
            ]
          }
        }
      }
    }
  ],
  "additionalProperties": true,
  "$defs": {
    "skillId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "skillIdArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/skillId"
      },
      "uniqueItems": true
    },
    "roleId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "semver": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][0-9A-Za-z.-]+)?$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "^/"
      }
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "nonEmptyStringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "inputOutputContract": {
      "type": "object",
      "required": [
        "required",
        "optional"
      ],
      "properties": {
        "required": {
          "$ref": "#/$defs/stringArray"
        },
        "optional": {
          "$ref": "#/$defs/stringArray"
        }
      },
      "additionalProperties": true
    },
    "outputContract": {
      "type": "object",
      "properties": {
        "primary": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "secondary": {
          "$ref": "#/$defs/stringArray"
        },
        "evidence": {
          "$ref": "#/$defs/stringArray"
        },
        "handoff": {
          "$ref": "#/$defs/stringArray"
        }
      },
      "anyOf": [
        {
          "required": [
            "primary"
          ]
        },
        {
          "required": [
            "evidence"
          ]
        }
      ],
      "additionalProperties": true
    },
    "externalTool": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        },
        "install_policy": {
          "type": "string",
          "enum": [
            "adaptation_point",
            "detect_only",
            "manual_install",
            "managed_install"
          ]
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "validatorClass": {
      "type": "string",
      "enum": [
        "schema_validation",
        "path_validation",
        "dependency_validation",
        "trace_validation",
        "process_validation",
        "domain_validation",
        "claim_validation"
      ]
    },
    "validationCommand": {
      "type": "object",
      "required": [
        "command"
      ],
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "validator_class": {
          "$ref": "#/$defs/validatorClass"
        },
        "mode": {
          "type": "string",
          "enum": [
            "required",
            "contextual",
            "optional"
          ]
        },
        "dry_runnable": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  }
}
