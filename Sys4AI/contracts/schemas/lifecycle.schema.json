{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sys4ai.example/contracts/lifecycle.schema.json",
  "title": "Lifecycle transition",
  "type": "object",
  "additionalProperties": false,
  "required": ["subject", "from_stage", "to_stage", "authorized_by", "evidence"],
  "properties": {
    "subject": {"type": "string", "minLength": 1},
    "from_stage": {"enum": ["Design", "Develop", "Implement", "Test", "Run", "Maintain", "Improve", "Retire"]},
    "to_stage": {"enum": ["Design", "Develop", "Implement", "Test", "Run", "Maintain", "Improve", "Retire"]},
    "authorized_by": {"type": "string", "minLength": 1},
    "evidence": {"type": "array", "items": {"type": "string"}, "minItems": 1}
  }
}
