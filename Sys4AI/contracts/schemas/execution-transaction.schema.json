{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sys4ai.example/contracts/execution-transaction.schema.json",
  "title": "Execution transaction",
  "type": "object",
  "additionalProperties": false,
  "required": ["transaction_id", "subject", "actor", "authorized_by", "actions", "permissions", "rollback", "stop_conditions"],
  "properties": {
    "transaction_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
    "subject": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "authorized_by": {"type": "string", "minLength": 1},
    "material_self_change": {"type": "boolean", "default": false},
    "approval_actor": {"type": ["string", "null"]},
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "target"],
        "properties": {
          "kind": {"enum": ["read", "write", "tool", "network", "external_write"]},
          "target": {"type": "string", "minLength": 1},
          "payload": {"type": "object"}
        }
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_reads", "allowed_writes", "allowed_tools", "network_allowed", "external_writes_allowed"],
      "properties": {
        "allowed_reads": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "allowed_writes": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "allowed_tools": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "network_allowed": {"type": "boolean"},
        "external_writes_allowed": {"type": "boolean"}
      }
    },
    "rollback": {"type": "string", "minLength": 1},
    "stop_conditions": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  }
}
