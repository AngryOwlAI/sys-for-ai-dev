{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sys4ai.example/contracts/assurance-case.schema.json",
  "title": "Assurance case",
  "type": "object",
  "additionalProperties": false,
  "required": ["case_id", "claim", "context", "evidence", "defeaters", "status"],
  "properties": {
    "case_id": {"type": "string", "minLength": 1},
    "claim": {"type": "string", "minLength": 1},
    "context": {"type": "array", "items": {"type": "string"}},
    "evidence": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "defeaters": {"type": "array", "items": {"type": "string"}},
    "status": {"enum": ["draft", "supported", "challenged", "rejected"]}
  }
}
