{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/Sys4AI/schemas/contracts/format_profile_registry_row.schema.json",
  "title": "Format profile registry row",
  "type": "object",
  "required": [
    "format_id",
    "extension",
    "format_family",
    "primary_role",
    "canonical_roots",
    "derivative_surfaces",
    "registry_required",
    "validator_required",
    "default_authority_class",
    "promotion_rule",
    "secrets_allowed",
    "notes"
  ],
  "properties": {
    "format_id": { "type": "string", "pattern": "^fmt_[a-z0-9_]+$" },
    "extension": { "type": "string", "minLength": 1 },
    "format_family": { "type": "string", "minLength": 1 },
    "registry_required": { "enum": ["true", "false"] },
    "validator_required": { "enum": ["true", "false"] },
    "secrets_allowed": { "enum": ["true", "false"] }
  },
  "additionalProperties": { "type": "string" }
}
