{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/Sys4AI/schemas/contracts/memory_preflight_receipt_v0_1.schema.json",
  "title": "Sys4AI historical memory preflight receipt v0.1",
  "description": "Read-only compatibility contract for historical execution records. Current writers never emit this shape.",
  "type": "object",
  "required": [
    "memory_preflight_receipt_id",
    "schema_version",
    "agentjob_id",
    "created_at",
    "status",
    "commands_run",
    "queries",
    "canonical_sources_inspected",
    "registry_rows_inspected",
    "stale_context_risks",
    "usable_for_routing"
  ],
  "properties": {
    "memory_preflight_receipt_id": { "type": "string", "minLength": 1 },
    "schema_version": { "const": "0.1.0" },
    "agentjob_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "status": { "enum": ["PASS", "PASS_WITH_WARNINGS", "FAIL", "BLOCKED"] },
    "commands_run": { "type": "array", "items": { "type": "object" } },
    "queries": { "type": "array", "items": { "type": "object" } },
    "canonical_sources_inspected": { "type": "array", "items": { "type": "object" } },
    "registry_rows_inspected": { "type": "array", "items": { "type": "object" } },
    "stale_context_risks": { "type": "array", "items": { "type": "object" } },
    "usable_for_routing": { "type": "boolean" }
  },
  "additionalProperties": true
}
