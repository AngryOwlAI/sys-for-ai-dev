{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/Sys4AI/schemas/contracts/handoff.schema.json",
  "title": "Sys4AI handoff",
  "type": "object",
  "required": [
    "handoff_id",
    "framework_name",
    "lifecycle_stage",
    "producing_role",
    "artifact_status",
    "summary",
    "source_artifacts",
    "format_profile_evidence",
    "source_authority_evidence",
    "derivative_surface_evidence",
    "open_issues",
    "next_recommended_role"
  ],
  "properties": {
    "handoff_id": { "type": "string", "minLength": 1 },
    "framework_name": { "const": "Sys4AI" },
    "lifecycle_stage": { "type": "string", "minLength": 1 },
    "producing_role": { "type": "string", "minLength": 1 },
    "artifact_status": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "source_artifacts": { "type": "array" },
    "format_profile_evidence": { "type": "object" },
    "source_authority_evidence": { "type": "object" },
    "derivative_surface_evidence": { "type": "object" },
    "open_issues": { "type": "array" },
    "next_recommended_role": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": true
}
