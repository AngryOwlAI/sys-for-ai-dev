{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/Sys4AI/schemas/contracts/program_state.schema.json",
  "title": "Sys4AI portable program state",
  "description": "Current framework state. Historical state snapshots use their versioned compatibility contracts and are never emitted through this schema.",
  "type": "object",
  "required": [
    "program_state_id",
    "schema_version",
    "system_context",
    "current_phase",
    "lifecycle_stage",
    "active_execution_transaction_id",
    "execution_profile_id",
    "current_state_evidence",
    "continuation_state",
    "cancellation_state",
    "escalation_state",
    "latest_closeout_evidence_id",
    "latest_handoff_evidence_id",
    "latest_memory_preflight_receipt_id",
    "capability_status_summary",
    "state_status",
    "blocked_reason",
    "human_gate_required",
    "allowed_next_actions",
    "blocked_actions",
    "validation_status"
  ],
  "properties": {
    "program_state_id": { "type": "string", "minLength": 1 },
    "schema_version": { "const": "1.0.0" },
    "system_context": {
      "type": "object",
      "required": [
        "framework_system",
        "development_system",
        "target_system",
        "self_hosting_mode",
        "reflection_depth"
      ],
      "properties": {
        "framework_system": { "const": "Sys4AI" },
        "development_system": { "const": "Sys4AI-dev" },
        "target_system": { "type": "string", "minLength": 1 },
        "self_hosting_mode": { "type": "boolean" },
        "reflection_depth": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "current_phase": { "type": "string", "minLength": 1 },
    "lifecycle_stage": { "type": "string", "minLength": 1 },
    "active_task_id": { "type": ["string", "null"] },
    "active_director_decision_id": { "type": ["string", "null"] },
    "active_execution_transaction_id": { "type": ["string", "null"] },
    "execution_profile_id": { "type": "string", "minLength": 1 },
    "current_state_evidence": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "continuation_state": { "enum": ["ready", "not_ready", "blocked", "complete"] },
    "cancellation_state": { "enum": ["not_requested", "requested", "cancelled"] },
    "escalation_state": { "enum": ["not_required", "pending", "escalated", "resolved"] },
    "latest_closeout_evidence_id": { "type": ["string", "null"] },
    "latest_handoff_evidence_id": { "type": ["string", "null"] },
    "latest_memory_preflight_receipt_id": { "type": ["string", "null"] },
    "capability_status_summary": {
      "type": "object",
      "required": [
        "portable_execution_contract",
        "current_state_model",
        "historical_compatibility",
        "removed_runtime_surfaces",
        "broader_semantic_validation",
        "safety_evaluation_controls"
      ],
      "properties": {
        "portable_execution_contract": { "enum": ["implemented", "partial", "deferred", "removed"] },
        "current_state_model": { "enum": ["implemented", "partial", "deferred", "removed"] },
        "historical_compatibility": { "enum": ["implemented", "partial", "deferred", "removed"] },
        "removed_runtime_surfaces": { "enum": ["absent", "present", "unknown"] },
        "broader_semantic_validation": { "enum": ["implemented", "partial", "deferred", "removed"] },
        "safety_evaluation_controls": { "enum": ["implemented", "partial", "deferred", "removed"] },
        "strategic_approval": { "enum": ["candidate", "accepted_G_08", "rejected", "revision_requested"] },
        "derivative_regeneration": { "enum": ["pending_G_09", "complete_G_09"] },
        "host_verification": { "enum": ["pending_G_07", "accepted_G_07_mixed_profile", "stale_G_07"] }
      },
      "additionalProperties": false
    },
    "state_status": { "enum": ["active", "blocked", "complete", "human_gated"] },
    "blocked_reason": { "type": ["string", "null"] },
    "human_gate_required": { "type": "boolean" },
    "allowed_next_actions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "blocked_actions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "validation_status": {
      "type": "object",
      "required": ["last_validated_at", "validators"],
      "properties": {
        "last_validated_at": { "type": "string", "minLength": 1 },
        "validators": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
