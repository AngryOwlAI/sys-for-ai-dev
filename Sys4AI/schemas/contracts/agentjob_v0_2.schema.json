{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/Sys4AI/schemas/contracts/agentjob_v0_2.schema.json",
  "title": "Sys4AI operational AgentJob v0.2",
  "type": "object",
  "required": [
    "agentjob_id",
    "schema_version",
    "status",
    "objective",
    "lifecycle_stage",
    "role_binding",
    "required_inputs",
    "allowed_reads",
    "allowed_writes",
    "forbidden_actions",
    "expected_outputs",
    "validators",
    "completion_evidence_required",
    "memory_preflight",
    "authority_boundary",
    "handoff_policy",
    "stop_conditions"
  ],
  "properties": {
    "agentjob_id": { "type": "string", "minLength": 1 },
    "schema_version": { "const": "0.2.0" },
    "status": {
      "enum": ["draft", "pending", "active", "completed", "blocked", "human_gated", "superseded", "cancelled"]
    },
    "objective": { "type": "string", "minLength": 1 },
    "lifecycle_stage": { "type": "string", "minLength": 1 },
    "role_binding": {
      "type": "object",
      "required": ["role_id", "binding_type", "authority_scope", "expires_with_agentjob"],
      "properties": {
        "role_id": { "type": "string", "minLength": 1 },
        "binding_type": {
          "enum": ["registered_role", "task_overlay", "one_job_provisional_role"]
        },
        "authority_scope": { "type": "string", "minLength": 1 },
        "expires_with_agentjob": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "required_inputs": { "type": "array", "items": { "type": "string" } },
    "allowed_reads": { "type": "array", "items": { "type": "string" } },
    "allowed_writes": { "type": "array", "items": { "type": "string" } },
    "generated_paths": { "type": "array", "items": { "type": "string" } },
    "forbidden_paths": { "type": "array", "items": { "type": "string" } },
    "forbidden_actions": { "type": "array", "items": { "type": "string" } },
    "expected_outputs": { "type": "array", "items": { "type": "string" } },
    "validators": { "type": "array", "items": { "type": "string" } },
    "completion_evidence_required": { "type": "array", "items": { "type": "string" } },
    "memory_preflight": {
      "type": "object",
      "required": ["required"],
      "properties": {
        "required": { "type": "boolean" },
        "minimum_queries": { "type": "array", "items": { "type": "string" } },
        "required_evidence": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "authority_boundary": { "type": "object" },
    "handoff_policy": { "type": "object" },
    "stop_conditions": { "type": "array", "items": { "type": "string" } },
    "supersedes": { "type": ["string", "null"] },
    "created_at": { "type": ["string", "null"] },
    "activated_at": { "type": ["string", "null"] }
  },
  "additionalProperties": true
}
