{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/Sys4AI/schemas/contracts/handoff_v0_2.schema.json",
  "title": "Sys4AI operational handoff v0.2",
  "type": "object",
  "required": [
    "handoff_id",
    "schema_version",
    "framework_name",
    "target_agentic_system",
    "artifact_name",
    "artifact_type",
    "artifact_version",
    "producing_role",
    "artifact_status",
    "summary",
    "source_artifacts",
    "traceability",
    "control_loop_notes",
    "memory_preflight",
    "format_profile_evidence",
    "source_authority_evidence",
    "derivative_surface_evidence",
    "security_evidence",
    "recommended_next_role",
    "phase_boundary_notes",
    "stop_conditions"
  ],
  "properties": {
    "handoff_id": { "type": "string", "minLength": 1 },
    "schema_version": { "const": "0.2.0" },
    "framework_name": { "const": "Sys4AI" },
    "target_agentic_system": { "type": "string", "minLength": 1 },
    "artifact_name": { "type": "string", "minLength": 1 },
    "artifact_type": { "type": "string", "minLength": 1 },
    "artifact_version": { "type": "string", "minLength": 1 },
    "producing_role": { "type": "string", "minLength": 1 },
    "artifact_status": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "source_artifacts": { "type": "array" },
    "traceability": { "type": "object" },
    "control_loop_notes": { "type": "object" },
    "memory_preflight": { "type": "object" },
    "format_profile_evidence": { "type": "object" },
    "source_authority_evidence": { "type": "object" },
    "derivative_surface_evidence": { "type": "object" },
    "security_evidence": { "type": "object" },
    "recommended_next_role": { "type": "string", "minLength": 1 },
    "phase_boundary_notes": { "type": "string" },
    "stop_conditions": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
