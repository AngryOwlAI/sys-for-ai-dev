{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/Sys4AI/schemas/contracts/handoff_registry_row.schema.json",
  "title": "Handoff registry row",
  "type": "object",
  "required": [
    "handoff_id", "path", "status", "execution_profile",
    "producing_execution_transaction_id", "next_execution_transaction_id",
    "producing_legacy_execution_id", "next_legacy_execution_id",
    "next_recommended_role", "source_ids", "supersedes", "source_hash",
    "last_validated_at", "notes"
  ],
  "properties": {
    "handoff_id": { "type": "string", "minLength": 1 },
    "path": { "type": "string", "minLength": 1 },
    "status": { "enum": ["draft", "pending", "active", "ready", "completed", "complete", "blocked", "human_gated", "superseded", "cancelled"] },
    "execution_profile": { "enum": ["portable_execution_transaction_v1", "legacy_execution_v0_2"] }
  },
  "additionalProperties": { "type": "string" }
}
