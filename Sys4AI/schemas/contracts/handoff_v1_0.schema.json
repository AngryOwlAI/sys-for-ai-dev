{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/Sys4AI/schemas/contracts/handoff_v1_0.schema.json",
  "title": "Sys4AI portable handoff v1.0",
  "type": "object",
  "required": [
    "handoff_id",
    "schema_version",
    "execution_profile_id",
    "producing_execution_transaction_id",
    "next_execution_transaction_id",
    "status",
    "producing_role",
    "recommended_next_role",
    "summary",
    "source_ids",
    "closeout_evidence_id",
    "current_state_evidence",
    "validation_evidence",
    "stop_conditions"
  ],
  "properties": {
    "handoff_id": { "type": "string", "minLength": 1 },
    "schema_version": { "const": "1.0.0" },
    "execution_profile_id": { "const": "portable_execution_transaction_v1" },
    "producing_execution_transaction_id": { "type": "string", "pattern": "^TX-[A-Z0-9]+(?:-[A-Z0-9]+)*$" },
    "next_execution_transaction_id": { "type": ["string", "null"], "pattern": "^TX-[A-Z0-9]+(?:-[A-Z0-9]+)*$" },
    "status": { "enum": ["ready", "blocked", "human_gated", "complete", "superseded", "cancelled"] },
    "producing_role": { "type": "string", "minLength": 1 },
    "recommended_next_role": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "source_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "closeout_evidence_id": { "type": "string", "minLength": 1 },
    "current_state_evidence": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "validation_evidence": { "type": "object", "minProperties": 1 },
    "stop_conditions": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
  },
  "additionalProperties": false
}
