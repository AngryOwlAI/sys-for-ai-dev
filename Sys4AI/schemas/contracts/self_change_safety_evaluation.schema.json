{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/Sys4AI/schemas/contracts/self_change_safety_evaluation.schema.json",
  "title": "Sys4AI Meta-Agent self-change safety evaluation packet",
  "type": "object",
  "required": [
    "packet_id",
    "schema_version",
    "subject_system",
    "subject_layer",
    "authority_status",
    "evaluation_status",
    "production_promotion_authorized",
    "source_requirement_ids",
    "candidate_value_ids",
    "open_gates",
    "change_under_evaluation",
    "separation_of_duties",
    "threat_model",
    "permission_scope_record",
    "verification_and_validation_plan",
    "evaluation_harness_plan",
    "assurance_case",
    "baseline_and_rollback_record",
    "operations_and_maintenance_plan",
    "reflection_control",
    "cross_layer_isolation",
    "hostile_input_handling",
    "data_and_memory_isolation",
    "holdout_protection",
    "limitation"
  ],
  "properties": {
    "packet_id": { "const": "SAFETY-EVAL-SFADEV-TX17-001" },
    "schema_version": { "const": "1.0.0" },
    "subject_system": {
      "type": "object",
      "required": ["system_id", "system_name"],
      "properties": {
        "system_id": { "const": "sys4ai" },
        "system_name": { "$ref": "#/$defs/nonEmptyString" }
      },
      "additionalProperties": false
    },
    "subject_layer": { "const": "framework_product" },
    "authority_status": { "const": "controlled" },
    "evaluation_status": { "const": "evaluated_pending_human_acceptance" },
    "production_promotion_authorized": { "const": false },
    "source_requirement_ids": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
    "candidate_value_ids": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
    "open_gates": {
      "type": "object",
      "required": ["G_07", "G_08", "TX_18", "production_readiness", "operational_authority"],
      "properties": {
        "G_07": { "const": "open" },
        "G_08": { "const": "open" },
        "TX_18": { "const": "not_started" },
        "production_readiness": { "const": "blocked" },
        "operational_authority": { "const": "blocked" }
      },
      "additionalProperties": false
    },
    "change_under_evaluation": {
      "type": "object",
      "required": [
        "change_id",
        "change_scope",
        "baseline_commit",
        "runtime_actor_id",
        "proposer_actor_id",
        "proposer_role_id",
        "executor_actor_id",
        "executor_role_id",
        "evaluator_actor_id",
        "evaluator_role_id",
        "acceptance_principal_id",
        "acceptance_principal_type",
        "acceptance_owner_role_id",
        "acceptance_status",
        "material_surfaces",
        "evaluation_result"
      ],
      "properties": {
        "change_id": { "$ref": "#/$defs/nonEmptyString" },
        "change_scope": { "const": "consequential_self_change" },
        "baseline_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "runtime_actor_id": { "$ref": "#/$defs/nonEmptyString" },
        "proposer_actor_id": { "$ref": "#/$defs/nonEmptyString" },
        "proposer_role_id": { "$ref": "#/$defs/nonEmptyString" },
        "executor_actor_id": { "$ref": "#/$defs/nonEmptyString" },
        "executor_role_id": { "$ref": "#/$defs/nonEmptyString" },
        "evaluator_actor_id": { "$ref": "#/$defs/nonEmptyString" },
        "evaluator_role_id": { "const": "verification_engineer" },
        "acceptance_principal_id": { "$ref": "#/$defs/nonEmptyString" },
        "acceptance_principal_type": { "const": "accountable_human" },
        "acceptance_owner_role_id": { "const": "system_director" },
        "acceptance_status": { "const": "pending_TX_18" },
        "material_surfaces": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
        "evaluation_result": { "const": "controls_pass_candidate_acceptance_blocked" }
      },
      "additionalProperties": false
    },
    "separation_of_duties": {
      "type": "object",
      "required": ["functions", "no_self_approval_categories", "enforcement"],
      "properties": {
        "functions": {
          "type": "object",
          "required": ["proposal", "approval", "execution", "evaluation", "acceptance"],
          "properties": {
            "proposal": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
            "approval": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
            "execution": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
            "evaluation": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
            "acceptance": { "$ref": "#/$defs/nonEmptyUniqueStringArray" }
          },
          "additionalProperties": false
        },
        "no_self_approval_categories": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
        "enforcement": { "$ref": "#/$defs/nonEmptyUniqueStringArray" }
      },
      "additionalProperties": false
    },
    "threat_model": { "$ref": "#/$defs/threatModel" },
    "permission_scope_record": { "$ref": "#/$defs/permissionScope" },
    "verification_and_validation_plan": { "$ref": "#/$defs/vvPlan" },
    "evaluation_harness_plan": { "$ref": "#/$defs/evaluationPlan" },
    "assurance_case": { "$ref": "#/$defs/assuranceCase" },
    "baseline_and_rollback_record": { "$ref": "#/$defs/baselineRecord" },
    "operations_and_maintenance_plan": { "$ref": "#/$defs/operationsPlan" },
    "reflection_control": {
      "type": "object",
      "required": [
        "default_maximum_depth",
        "unbounded_recursive_self_improvement_allowed",
        "expansion_requirements",
        "failure_behavior"
      ],
      "properties": {
        "default_maximum_depth": { "const": 1 },
        "unbounded_recursive_self_improvement_allowed": { "const": false },
        "expansion_requirements": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
        "failure_behavior": { "const": "stop_and_escalate" }
      },
      "additionalProperties": false
    },
    "cross_layer_isolation": {
      "type": "object",
      "required": ["protected_framework_surfaces", "cross_layer_write_requires_decision_and_envelope", "failure_behavior"],
      "properties": {
        "protected_framework_surfaces": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
        "cross_layer_write_requires_decision_and_envelope": { "const": true },
        "failure_behavior": { "const": "block_and_escalate" }
      },
      "additionalProperties": false
    },
    "hostile_input_handling": {
      "type": "object",
      "required": ["retrieved_content_is_untrusted_by_default", "input_classes", "required_controls", "failure_behavior"],
      "properties": {
        "retrieved_content_is_untrusted_by_default": { "const": true },
        "input_classes": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
        "required_controls": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
        "failure_behavior": { "const": "block_external_action" }
      },
      "additionalProperties": false
    },
    "data_and_memory_isolation": {
      "type": "object",
      "required": [
        "target_namespace_required",
        "cross_target_authority_inheritance_allowed",
        "sensitive_data_minimization_required",
        "retention_and_deletion_required",
        "cross_target_access_record_required"
      ],
      "properties": {
        "target_namespace_required": { "const": true },
        "cross_target_authority_inheritance_allowed": { "const": false },
        "sensitive_data_minimization_required": { "const": true },
        "retention_and_deletion_required": { "const": true },
        "cross_target_access_record_required": { "const": true }
      },
      "additionalProperties": false
    },
    "holdout_protection": {
      "type": "object",
      "required": [
        "suite_path",
        "expected_sha256",
        "expected_scenario_count",
        "protection_mode",
        "target_actor_may_modify",
        "mutation_requires",
        "rotation_trigger"
      ],
      "properties": {
        "suite_path": { "$ref": "#/$defs/relativePath" },
        "expected_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "expected_scenario_count": { "type": "integer", "minimum": 1 },
        "protection_mode": { "const": "integrity_and_mutation_control_not_secrecy" },
        "target_actor_may_modify": { "const": false },
        "mutation_requires": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
        "rotation_trigger": { "$ref": "#/$defs/nonEmptyString" }
      },
      "additionalProperties": false
    },
    "limitation": { "$ref": "#/$defs/nonEmptyString" }
  },
  "additionalProperties": false,
  "$defs": {
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "relativePath": { "type": "string", "minLength": 1, "pattern": "^(?!/).*$" },
    "nonEmptyUniqueStringArray": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "artifactBase": {
      "type": "object",
      "required": ["artifact_id", "owner_role_id"],
      "properties": {
        "artifact_id": { "$ref": "#/$defs/nonEmptyString" },
        "owner_role_id": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "threatModel": {
      "type": "object",
      "required": ["artifact_id", "owner_role_id", "boundary", "actors", "assets", "data_flows", "tools", "threats", "residual_summary"],
      "properties": {
        "artifact_id": { "$ref": "#/$defs/nonEmptyString" },
        "owner_role_id": { "const": "security_safety_privacy_compliance_reviewer" },
        "boundary": { "$ref": "#/$defs/nonEmptyString" },
        "actors": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
        "assets": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
        "data_flows": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
        "tools": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
        "threats": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["threat_id", "category", "materiality", "owner_role_id", "control_ids", "verification_ids", "residual_status", "residual_risk"],
            "properties": {
              "threat_id": { "$ref": "#/$defs/nonEmptyString" },
              "category": { "$ref": "#/$defs/nonEmptyString" },
              "materiality": { "enum": ["high", "critical"] },
              "owner_role_id": { "$ref": "#/$defs/nonEmptyString" },
              "control_ids": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
              "verification_ids": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
              "residual_status": { "enum": ["mitigated", "deferred", "blocked"] },
              "residual_risk": { "$ref": "#/$defs/nonEmptyString" }
            },
            "additionalProperties": false
          }
        },
        "residual_summary": { "$ref": "#/$defs/nonEmptyString" }
      },
      "additionalProperties": false
    },
    "permissionScope": {
      "type": "object",
      "required": [
        "artifact_id",
        "owner_role_id",
        "permission_precedence",
        "required_envelope_fields",
        "least_privilege_default",
        "current_envelope_required_for_execution",
        "missing_or_denied_fails_closed",
        "values_may_expand_permissions",
        "credential_rule",
        "external_action_rule"
      ],
      "properties": {
        "artifact_id": { "$ref": "#/$defs/nonEmptyString" },
        "owner_role_id": { "const": "security_safety_privacy_compliance_reviewer" },
        "permission_precedence": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
        "required_envelope_fields": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
        "least_privilege_default": { "const": true },
        "current_envelope_required_for_execution": { "const": true },
        "missing_or_denied_fails_closed": { "const": true },
        "values_may_expand_permissions": { "const": false },
        "credential_rule": { "$ref": "#/$defs/nonEmptyString" },
        "external_action_rule": { "$ref": "#/$defs/nonEmptyString" }
      },
      "additionalProperties": false
    },
    "vvPlan": {
      "type": "object",
      "required": ["artifact_id", "owner_role_id", "requirement_mappings", "evidence_classes", "acceptance_rule", "residual_uncertainty"],
      "properties": {
        "artifact_id": { "$ref": "#/$defs/nonEmptyString" },
        "owner_role_id": { "const": "verification_engineer" },
        "requirement_mappings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["requirement_id", "evidence_type", "evidence_paths", "status"],
            "properties": {
              "requirement_id": { "$ref": "#/$defs/nonEmptyString" },
              "evidence_type": { "$ref": "#/$defs/nonEmptyString" },
              "evidence_paths": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
              "status": { "enum": ["pass", "partial", "not_run_pending_TX_18"] }
            },
            "additionalProperties": false
          }
        },
        "evidence_classes": {
          "type": "array",
          "minItems": 4,
          "items": {
            "type": "object",
            "required": ["evidence_class", "question", "status", "evidence_paths"],
            "properties": {
              "evidence_class": { "$ref": "#/$defs/nonEmptyString" },
              "question": { "$ref": "#/$defs/nonEmptyString" },
              "status": { "enum": ["executed", "executed_on_reference_holdouts", "not_run_pending_TX_18"] },
              "evidence_paths": {
                "type": "array",
                "uniqueItems": true,
                "items": { "$ref": "#/$defs/nonEmptyString" }
              }
            },
            "additionalProperties": false
          }
        },
        "acceptance_rule": { "$ref": "#/$defs/nonEmptyString" },
        "residual_uncertainty": { "$ref": "#/$defs/nonEmptyString" }
      },
      "additionalProperties": false
    },
    "evaluationPlan": {
      "type": "object",
      "required": ["artifact_id", "owner_role_id", "target_behavior", "holdout_suite_path", "rubric", "exploratory_evaluation", "acceptance_gate", "regression_cadence", "limitations"],
      "properties": {
        "artifact_id": { "$ref": "#/$defs/nonEmptyString" },
        "owner_role_id": { "const": "verification_engineer" },
        "target_behavior": { "$ref": "#/$defs/nonEmptyString" },
        "holdout_suite_path": { "$ref": "#/$defs/relativePath" },
        "rubric": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
        "exploratory_evaluation": { "$ref": "#/$defs/nonEmptyString" },
        "acceptance_gate": { "$ref": "#/$defs/nonEmptyString" },
        "regression_cadence": { "$ref": "#/$defs/nonEmptyString" },
        "limitations": { "$ref": "#/$defs/nonEmptyUniqueStringArray" }
      },
      "additionalProperties": false
    },
    "assuranceCase": {
      "type": "object",
      "required": ["artifact_id", "owner_role_id", "claims", "assumptions", "residual_risks"],
      "properties": {
        "artifact_id": { "$ref": "#/$defs/nonEmptyString" },
        "owner_role_id": { "const": "security_safety_privacy_compliance_reviewer" },
        "claims": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["claim_id", "statement", "status", "evidence_paths", "gap_or_residual"],
            "properties": {
              "claim_id": { "$ref": "#/$defs/nonEmptyString" },
              "statement": { "$ref": "#/$defs/nonEmptyString" },
              "status": { "enum": ["supported", "partial", "gap"] },
              "evidence_paths": {
                "type": "array",
                "uniqueItems": true,
                "items": { "$ref": "#/$defs/nonEmptyString" }
              },
              "gap_or_residual": { "$ref": "#/$defs/nonEmptyString" }
            },
            "additionalProperties": false
          }
        },
        "assumptions": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
        "residual_risks": { "$ref": "#/$defs/nonEmptyUniqueStringArray" }
      },
      "additionalProperties": false
    },
    "baselineRecord": {
      "type": "object",
      "required": ["artifact_id", "owner_role_id", "change_class", "baseline_commit", "protected_artifacts", "preserved_trace_state", "rollback_triggers", "rollback_actions", "supersession_rule"],
      "properties": {
        "artifact_id": { "$ref": "#/$defs/nonEmptyString" },
        "owner_role_id": { "const": "svc_documentation_surface_architect" },
        "change_class": { "const": "additive_control_baseline" },
        "baseline_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "protected_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["path", "sha256"],
            "properties": {
              "path": { "$ref": "#/$defs/relativePath" },
              "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
            },
            "additionalProperties": false
          }
        },
        "preserved_trace_state": {
          "type": "object",
          "required": ["path", "rows", "needs_evidence", "planned_verification"],
          "properties": {
            "path": { "$ref": "#/$defs/relativePath" },
            "rows": { "type": "integer", "minimum": 1 },
            "needs_evidence": { "type": "integer", "minimum": 0 },
            "planned_verification": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "rollback_triggers": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
        "rollback_actions": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
        "supersession_rule": { "$ref": "#/$defs/nonEmptyString" }
      },
      "additionalProperties": false
    },
    "operationsPlan": {
      "type": "object",
      "required": ["artifact_id", "owner_role_id", "operational_boundary", "production_readiness", "operational_authority", "monitoring_signals", "incident_paths", "maintenance_cadence", "retention", "handoff_points", "unresolved_readiness_gaps"],
      "properties": {
        "artifact_id": { "$ref": "#/$defs/nonEmptyString" },
        "owner_role_id": { "const": "runtime_maintenance_planner" },
        "operational_boundary": { "$ref": "#/$defs/nonEmptyString" },
        "production_readiness": { "const": "blocked" },
        "operational_authority": { "const": "not_granted" },
        "monitoring_signals": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
        "incident_paths": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
        "maintenance_cadence": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
        "retention": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
        "handoff_points": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
        "unresolved_readiness_gaps": { "$ref": "#/$defs/nonEmptyUniqueStringArray" }
      },
      "additionalProperties": false
    }
  }
}
