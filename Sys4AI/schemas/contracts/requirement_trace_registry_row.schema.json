{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/Sys4AI/schemas/contracts/requirement_trace_registry_row.schema.json",
  "title": "Requirement trace registry row",
  "type": "object",
  "required": [
    "trace_id",
    "phase0_selector",
    "phase0_source",
    "coverage_status",
    "trace_class",
    "semantic_justification",
    "semantic_review_verdict",
    "phase1_selectors",
    "evidence_paths",
    "notes"
  ],
  "properties": {
    "trace_id": { "type": "string", "pattern": "^TRACE-[A-Z0-9-]+$" },
    "phase0_selector": {
      "type": "string",
      "pattern": "^SFA-(?:CORE|P0)-[A-Z0-9]+(?:-[A-Z0-9]+)*-[0-9]{3}$"
    },
    "phase0_source": { "type": "string", "minLength": 1 },
    "coverage_status": { "enum": ["covered", "partial", "deferred", "not_applicable"] },
    "trace_class": { "enum": ["implemented", "scaffolded", "deferred", "out_of_phase"] },
    "semantic_justification": { "type": "string" },
    "semantic_review_verdict": {
      "enum": ["", "sufficient", "needs_evidence", "incorrect_mapping"]
    },
    "phase1_selectors": { "type": "string" },
    "evidence_paths": { "type": "string", "minLength": 1 },
    "notes": { "type": "string" }
  },
  "allOf": [
    {
      "if": { "properties": { "coverage_status": { "const": "covered" } } },
      "then": { "properties": { "trace_class": { "const": "implemented" } } }
    },
    {
      "if": { "properties": { "coverage_status": { "const": "partial" } } },
      "then": {
        "properties": {
          "trace_class": { "enum": ["scaffolded", "deferred", "out_of_phase"] },
          "semantic_justification": { "minLength": 1 }
        }
      }
    },
    {
      "if": { "properties": { "coverage_status": { "const": "deferred" } } },
      "then": {
        "properties": {
          "trace_class": { "const": "deferred" },
          "semantic_justification": { "minLength": 1 }
        }
      }
    },
    {
      "if": { "properties": { "coverage_status": { "const": "not_applicable" } } },
      "then": {
        "properties": {
          "trace_class": { "const": "out_of_phase" },
          "semantic_justification": { "minLength": 1 }
        }
      }
    },
    {
      "if": {
        "properties": {
          "trace_class": { "enum": ["scaffolded", "deferred", "out_of_phase"] }
        }
      },
      "then": {
        "properties": {
          "semantic_review_verdict": {
            "enum": ["sufficient", "needs_evidence", "incorrect_mapping"]
          }
        }
      }
    }
  ],
  "additionalProperties": { "type": "string" }
}
