{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/Sys4AI/schemas/contracts/requirement_trace_registry_row.schema.json",
  "title": "Requirement trace registry row",
  "description": "Versioned transition contract for legacy Phase 0-to-Phase 1 trace rows and generalized 2.0.0 lifecycle, capability, verification, evidence, and semantic-review rows. Schema conformance does not prove semantic sufficiency or current capability.",
  "oneOf": [
    { "$ref": "#/$defs/legacyRow" },
    { "$ref": "#/$defs/generalizedRow" }
  ],
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "optionalString": {
      "type": "string"
    },
    "traceId": {
      "type": "string",
      "pattern": "^TRACE-[A-Z0-9-]+$"
    },
    "requirementId": {
      "type": "string",
      "pattern": "^SFA-[A-Z0-9]+(?:-[A-Z0-9]+)*$"
    },
    "phase0RequirementId": {
      "type": "string",
      "pattern": "^SFA-(?:CORE|P0)-[A-Z0-9]+(?:-[A-Z0-9]+)*-[0-9]{3}$"
    },
    "legacyRow": {
      "type": "object",
      "required": [
        "trace_id",
        "phase0_selector",
        "phase0_source",
        "coverage_status",
        "trace_class",
        "semantic_justification",
        "semantic_review_verdict",
        "phase1_selectors",
        "evidence_paths",
        "notes"
      ],
      "properties": {
        "trace_id": { "$ref": "#/$defs/traceId" },
        "phase0_selector": { "$ref": "#/$defs/phase0RequirementId" },
        "phase0_source": { "$ref": "#/$defs/nonEmptyString" },
        "coverage_status": {
          "enum": ["covered", "partial", "deferred", "not_applicable"]
        },
        "trace_class": {
          "enum": ["implemented", "scaffolded", "deferred", "out_of_phase"]
        },
        "semantic_justification": { "$ref": "#/$defs/optionalString" },
        "semantic_review_verdict": {
          "enum": ["", "sufficient", "needs_evidence", "incorrect_mapping"]
        },
        "phase1_selectors": { "$ref": "#/$defs/optionalString" },
        "evidence_paths": { "$ref": "#/$defs/nonEmptyString" },
        "notes": { "$ref": "#/$defs/optionalString" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "coverage_status": { "const": "covered" } },
            "required": ["coverage_status"]
          },
          "then": {
            "properties": { "trace_class": { "const": "implemented" } }
          }
        },
        {
          "if": {
            "properties": { "coverage_status": { "const": "partial" } },
            "required": ["coverage_status"]
          },
          "then": {
            "properties": {
              "trace_class": {
                "enum": ["scaffolded", "deferred", "out_of_phase"]
              },
              "semantic_justification": { "minLength": 1 }
            }
          }
        },
        {
          "if": {
            "properties": { "coverage_status": { "const": "deferred" } },
            "required": ["coverage_status"]
          },
          "then": {
            "properties": {
              "trace_class": { "const": "deferred" },
              "semantic_justification": { "minLength": 1 }
            }
          }
        },
        {
          "if": {
            "properties": { "coverage_status": { "const": "not_applicable" } },
            "required": ["coverage_status"]
          },
          "then": {
            "properties": {
              "trace_class": { "const": "out_of_phase" },
              "semantic_justification": { "minLength": 1 }
            }
          }
        },
        {
          "if": {
            "properties": {
              "trace_class": {
                "enum": ["scaffolded", "deferred", "out_of_phase"]
              }
            },
            "required": ["trace_class"]
          },
          "then": {
            "properties": {
              "semantic_review_verdict": {
                "enum": ["sufficient", "needs_evidence", "incorrect_mapping"]
              }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "generalizedRow": {
      "type": "object",
      "required": [
        "schema_version",
        "trace_id",
        "requirement_id",
        "requirement_source_id",
        "requirement_lifecycle",
        "applicability_status",
        "coverage_status",
        "capability_status",
        "verification_status",
        "verification_waiver_id",
        "evidence_status",
        "implementation_artifacts",
        "validation_evidence",
        "evidence_paths",
        "semantic_review_owner",
        "semantic_review_date",
        "semantic_review_verdict",
        "supersedes",
        "phase0_selector",
        "phase0_source",
        "legacy_coverage_status",
        "trace_class",
        "semantic_justification",
        "legacy_semantic_review_verdict",
        "phase1_selectors",
        "notes"
      ],
      "properties": {
        "schema_version": { "const": "2.0.0" },
        "trace_id": { "$ref": "#/$defs/traceId" },
        "requirement_id": { "$ref": "#/$defs/requirementId" },
        "requirement_source_id": { "$ref": "#/$defs/nonEmptyString" },
        "requirement_lifecycle": {
          "enum": ["proposed", "active", "deprecated", "superseded", "retired"]
        },
        "applicability_status": {
          "enum": ["required", "optional_profile", "not_applicable", "not_reviewed"]
        },
        "coverage_status": {
          "enum": ["missing", "partial", "covered", "not_applicable"]
        },
        "capability_status": {
          "enum": ["absent", "scaffolded", "implemented", "operational", "suspended", "removed"]
        },
        "verification_status": {
          "enum": ["not_planned", "planned", "not_run", "pass", "fail", "waived", "not_applicable"]
        },
        "verification_waiver_id": { "$ref": "#/$defs/optionalString" },
        "evidence_status": {
          "enum": ["current", "historical", "stale", "missing"]
        },
        "implementation_artifacts": { "$ref": "#/$defs/optionalString" },
        "validation_evidence": { "$ref": "#/$defs/optionalString" },
        "evidence_paths": { "$ref": "#/$defs/nonEmptyString" },
        "semantic_review_owner": { "$ref": "#/$defs/nonEmptyString" },
        "semantic_review_date": {
          "type": "string",
          "pattern": "^(?:|[0-9]{4}-[0-9]{2}-[0-9]{2})$"
        },
        "semantic_review_verdict": {
          "enum": ["sufficient", "needs_evidence", "incorrect_mapping", "not_reviewed"]
        },
        "supersedes": { "$ref": "#/$defs/optionalString" },
        "phase0_selector": { "$ref": "#/$defs/phase0RequirementId" },
        "phase0_source": { "$ref": "#/$defs/nonEmptyString" },
        "legacy_coverage_status": {
          "enum": ["covered", "partial", "deferred", "not_applicable"]
        },
        "trace_class": {
          "enum": ["implemented", "scaffolded", "deferred", "out_of_phase"]
        },
        "semantic_justification": { "$ref": "#/$defs/optionalString" },
        "legacy_semantic_review_verdict": {
          "enum": ["", "sufficient", "needs_evidence", "incorrect_mapping"]
        },
        "phase1_selectors": { "$ref": "#/$defs/optionalString" },
        "notes": { "$ref": "#/$defs/optionalString" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "capability_status": {
                "enum": ["implemented", "operational"]
              }
            },
            "required": ["capability_status"]
          },
          "then": {
            "properties": {
              "implementation_artifacts": { "minLength": 1 }
            }
          }
        },
        {
          "if": {
            "properties": { "capability_status": { "const": "operational" } },
            "required": ["capability_status"]
          },
          "then": {
            "properties": {
              "verification_status": { "const": "pass" },
              "evidence_status": { "const": "current" },
              "validation_evidence": { "minLength": 1 }
            }
          }
        },
        {
          "if": {
            "properties": { "capability_status": { "const": "removed" } },
            "required": ["capability_status"]
          },
          "then": {
            "properties": {
              "implementation_artifacts": { "const": "" },
              "evidence_status": { "enum": ["current", "historical"] },
              "evidence_paths": { "minLength": 1 }
            }
          }
        },
        {
          "if": {
            "properties": { "evidence_status": { "const": "current" } },
            "required": ["evidence_status"]
          },
          "then": {
            "properties": { "evidence_paths": { "minLength": 1 } }
          }
        },
        {
          "if": {
            "properties": { "verification_status": { "const": "pass" } },
            "required": ["verification_status"]
          },
          "then": {
            "properties": { "validation_evidence": { "minLength": 1 } }
          }
        },
        {
          "if": {
            "properties": { "verification_status": { "const": "waived" } },
            "required": ["verification_status"]
          },
          "then": {
            "properties": { "verification_waiver_id": { "minLength": 1 } }
          },
          "else": {
            "properties": { "verification_waiver_id": { "const": "" } }
          }
        },
        {
          "if": {
            "properties": {
              "requirement_lifecycle": {
                "enum": ["deprecated", "superseded", "retired"]
              }
            },
            "required": ["requirement_lifecycle"]
          },
          "then": {
            "properties": {
              "capability_status": {
                "enum": ["absent", "scaffolded", "implemented", "suspended", "removed"]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "semantic_review_verdict": { "const": "not_reviewed" }
            },
            "required": ["semantic_review_verdict"]
          },
          "then": {
            "properties": { "semantic_review_date": { "const": "" } }
          },
          "else": {
            "properties": {
              "semantic_review_date": {
                "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
              }
            }
          }
        },
        {
          "properties": {
            "requirement_id": { "$ref": "#/$defs/requirementId" },
            "phase0_selector": { "$ref": "#/$defs/phase0RequirementId" },
            "requirement_source_id": { "$ref": "#/$defs/nonEmptyString" },
            "phase0_source": { "$ref": "#/$defs/nonEmptyString" }
          }
        }
      ],
      "additionalProperties": false
    }
  }
}
