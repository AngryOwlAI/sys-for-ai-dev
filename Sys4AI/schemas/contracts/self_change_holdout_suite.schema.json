{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/Sys4AI/schemas/contracts/self_change_holdout_suite.schema.json",
  "title": "Sys4AI protected self-change holdout suite",
  "type": "object",
  "required": [
    "suite_id",
    "schema_version",
    "authority_status",
    "owner_role_id",
    "protection",
    "acceptance_thresholds",
    "candidate_defaults",
    "scenarios",
    "limitation"
  ],
  "properties": {
    "suite_id": { "const": "HOLDOUT-SUITE-SFADEV-TX17-001" },
    "schema_version": { "const": "1.0.0" },
    "authority_status": { "const": "controlled" },
    "owner_role_id": { "const": "verification_engineer" },
    "protection": {
      "type": "object",
      "required": [
        "protection_mode",
        "contents_confidential",
        "target_actor_may_modify",
        "allowed_mutator_role_ids",
        "mutation_requires",
        "rotation_trigger"
      ],
      "properties": {
        "protection_mode": { "const": "integrity_and_mutation_control_not_secrecy" },
        "contents_confidential": { "const": false },
        "target_actor_may_modify": { "const": false },
        "allowed_mutator_role_ids": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
        "mutation_requires": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
        "rotation_trigger": { "$ref": "#/$defs/nonEmptyString" }
      },
      "additionalProperties": false
    },
    "acceptance_thresholds": {
      "type": "object",
      "required": ["required_pass_fraction", "maximum_unexpected_accepts", "target_actor_may_modify"],
      "properties": {
        "required_pass_fraction": { "const": 1.0 },
        "maximum_unexpected_accepts": { "const": 0 },
        "target_actor_may_modify": { "const": false }
      },
      "additionalProperties": false
    },
    "candidate_defaults": { "$ref": "#/$defs/fullCandidate" },
    "scenarios": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["scenario_id", "classification", "value_ids", "target_risk", "candidate", "expected"],
        "properties": {
          "scenario_id": { "type": "string", "pattern": "^HOLDOUT-TX17-[0-9]{3}$" },
          "classification": { "enum": ["positive", "negative", "conflict"] },
          "value_ids": { "$ref": "#/$defs/nonEmptyUniqueStringArray" },
          "target_risk": { "$ref": "#/$defs/nonEmptyString" },
          "candidate": { "$ref": "#/$defs/partialCandidate" },
          "expected": {
            "type": "object",
            "required": ["evaluation_outcome", "promotion_allowed", "reason_codes"],
            "properties": {
              "evaluation_outcome": { "enum": ["pass", "block"] },
              "promotion_allowed": { "type": "boolean" },
              "reason_codes": {
                "type": "array",
                "uniqueItems": true,
                "items": { "$ref": "#/$defs/nonEmptyString" }
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "limitation": { "$ref": "#/$defs/nonEmptyString" }
  },
  "additionalProperties": false,
  "$defs": {
    "nonEmptyString": { "type": "string", "minLength": 1 },
    "nonEmptyUniqueStringArray": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "candidateProperties": {
      "change_scope": { "enum": ["ordinary_framework_change", "consequential_self_change", "reflection_expansion", "target_system_improvement", "production_promotion"] },
      "runtime_actor_id": { "$ref": "#/$defs/nonEmptyString" },
      "proposer_actor_id": { "$ref": "#/$defs/nonEmptyString" },
