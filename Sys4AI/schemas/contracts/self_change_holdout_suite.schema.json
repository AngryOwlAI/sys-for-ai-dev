      "approval_principal_id": { "$ref": "#/$defs/nonEmptyString" },
      "approval_principal_type": { "enum": ["accountable_human", "meta_agent_runtime", "automated_evaluator"] },
      "acceptance_principal_id": { "$ref": "#/$defs/nonEmptyString" },
      "acceptance_principal_type": { "enum": ["accountable_human", "meta_agent_runtime", "automated_evaluator"] },
      "execution_requested": { "type": "boolean" },
